# Server Config
PORT=4000

# Database
MONGO_URI=mongodb://localhost:27017/medikto

# JWT Token Secret
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary (Media upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Fast2SMS (Optional fallback provider)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Twilio SMS Provider Config
# Populate these keys to switch the SMS dispatch system automatically from Fast2SMS to Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here # e.g. +18559092429
